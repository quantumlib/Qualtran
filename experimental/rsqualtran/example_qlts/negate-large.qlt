# Qualtran-L1
# 1.0.0

qdef Negate
[
    x: QInt(2048),
] {
    x2                   = BitwiseNot(2048) [x=x]               
    x3                   = AddK(k=1)        [x=x2]              
                           return           [x=x3]              
}


qdef BitwiseNot(2048)
[
    x: QInt(2048),
] {
    q                    = X(oneach=2048)   [q=x]               
                           return           [x=q]               
}


qdef AddK(k=1)
[
    x: QInt(2048),
] {
    reg                  = Allocate(QInt(2048))[]                  
    x2                   = XorK(1)          [x=reg]             
    a, b                 = Always(Add)      [a=x2, b=x]         
    x3                   = XorK(1)          [x=a]               
    |                    = Free(QInt(2048)) [reg=x3]            
                           return           [x=b]               
}


qdef X(oneach=2048)
