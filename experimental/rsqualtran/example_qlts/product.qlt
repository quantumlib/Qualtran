qdef Add
[
    a: QUInt(32),
    b: QUInt(64),
] {
    reg                  = Split(QUInt(32)) [reg=a]             
    reg2                 = Split(QUInt(64)) [reg=b]             
    ctrl, target         = And              [ctrl=[reg[31], reg2[63]]]
    ctrl2, target2       = CNOT             [ctrl=target, target=reg[30]]
    ctrl3, target3       = CNOT             [ctrl=ctrl2, target=reg2[62]]
    ctrl4, target4       = And              [ctrl=[target2, target3]]
    ctrl5, target5       = CNOT             [ctrl=ctrl3, target=target4]
    ctrl6, target6       = CNOT             [ctrl=target5, target=reg[29]]
    ctrl7, target7       = CNOT             [ctrl=ctrl6, target=reg2[61]]
    ctrl8, target8       = And              [ctrl=[target6, target7]]
