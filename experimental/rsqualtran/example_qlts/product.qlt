qdef Product
[
    a: QUInt(32),
    b: QUInt(32),
    result: | -> QUInt(64),
] {
    reg                  = Allocate(QUInt(64))[]                  
    a2, b2, result       = PlusEqualProduct [a=a, b=b, result=reg]
                           return           [a=a2, b=b2, result=result]
}


