    ctrl203, target184   = CNOT             [ctrl=ctrl49, target=ctrl201]
    ctrl204              = And_dag          [ctrl=[ctrl48[0], ctrl48[1]], target=target184]
    ctrl205, target185   = CNOT             [ctrl=ctrl203, target=ctrl204[0]]
    ctrl206, target186   = CNOT             [ctrl=target185, target=ctrl204[1]]
    ctrl207, target187   = CNOT             [ctrl=ctrl45, target=ctrl205]
    ctrl208              = And_dag          [ctrl=[ctrl44[0], ctrl44[1]], target=target187]
    ctrl209, target188   = CNOT             [ctrl=ctrl207, target=ctrl208[0]]
    ctrl210, target189   = CNOT             [ctrl=target188, target=ctrl208[1]]
    ctrl211, target190   = CNOT             [ctrl=ctrl41, target=ctrl209]
    ctrl212              = And_dag          [ctrl=[ctrl40[0], ctrl40[1]], target=target190]
    ctrl213, target191   = CNOT             [ctrl=ctrl211, target=ctrl212[0]]
    ctrl214, target192   = CNOT             [ctrl=target191, target=ctrl212[1]]
    ctrl215, target193   = CNOT             [ctrl=ctrl37, target=ctrl213]
    ctrl216              = And_dag          [ctrl=[ctrl36[0], ctrl36[1]], target=target193]
    ctrl217, target194   = CNOT             [ctrl=ctrl215, target=ctrl216[0]]
    ctrl218, target195   = CNOT             [ctrl=target194, target=ctrl216[1]]
    ctrl219, target196   = CNOT             [ctrl=ctrl33, target=ctrl217]
    ctrl220              = And_dag          [ctrl=[ctrl32[0], ctrl32[1]], target=target196]
    ctrl221, target197   = CNOT             [ctrl=ctrl219, target=ctrl220[0]]
    ctrl222, target198   = CNOT             [ctrl=target197, target=ctrl220[1]]
    ctrl223, target199   = CNOT             [ctrl=ctrl29, target=ctrl221]
    ctrl224              = And_dag          [ctrl=[ctrl28[0], ctrl28[1]], target=target199]
    ctrl225, target200   = CNOT             [ctrl=ctrl223, target=ctrl224[0]]
    ctrl226, target201   = CNOT             [ctrl=target200, target=ctrl224[1]]
    ctrl227, target202   = CNOT             [ctrl=ctrl25, target=ctrl225]
    ctrl228              = And_dag          [ctrl=[ctrl24[0], ctrl24[1]], target=target202]
    ctrl229, target203   = CNOT             [ctrl=ctrl227, target=ctrl228[0]]
    ctrl230, target204   = CNOT             [ctrl=target203, target=ctrl228[1]]
    ctrl231, target205   = CNOT             [ctrl=ctrl21, target=ctrl229]
    ctrl232              = And_dag          [ctrl=[ctrl20[0], ctrl20[1]], target=target205]
    ctrl233, target206   = CNOT             [ctrl=ctrl231, target=ctrl232[0]]
    ctrl234, target207   = CNOT             [ctrl=target206, target=ctrl232[1]]
    ctrl235, target208   = CNOT             [ctrl=ctrl17, target=ctrl233]
    ctrl236              = And_dag          [ctrl=[ctrl16[0], ctrl16[1]], target=target208]
    ctrl237, target209   = CNOT             [ctrl=ctrl235, target=ctrl236[0]]
    ctrl238, target210   = CNOT             [ctrl=target209, target=ctrl236[1]]
    ctrl239, target211   = CNOT             [ctrl=ctrl13, target=ctrl237]
    ctrl240              = And_dag          [ctrl=[ctrl12[0], ctrl12[1]], target=target211]
    ctrl241, target212   = CNOT             [ctrl=ctrl239, target=ctrl240[0]]
    ctrl242, target213   = CNOT             [ctrl=target212, target=ctrl240[1]]
    ctrl243, target214   = CNOT             [ctrl=ctrl9, target=ctrl241]
    ctrl244              = And_dag          [ctrl=[ctrl8[0], ctrl8[1]], target=target214]
    ctrl245, target215   = CNOT             [ctrl=ctrl243, target=ctrl244[0]]
    ctrl246, target216   = CNOT             [ctrl=target215, target=ctrl244[1]]
    ctrl247, target217   = CNOT             [ctrl=ctrl5, target=ctrl245]
    ctrl248              = And_dag          [ctrl=[ctrl4[0], ctrl4[1]], target=target217]
    ctrl249, target218   = CNOT             [ctrl=ctrl247, target=ctrl248[0]]
    ctrl250              = And_dag          [ctrl=[ctrl[0], ctrl[1]], target=ctrl249]
    ctrl251, target219   = CNOT             [ctrl=target218, target=ctrl248[1]]
    ctrl252, target220   = CNOT             [ctrl=ctrl250[0], target=ctrl250[1]]
    reg3                 = Join(QUInt(32))  [reg=[ctrl130, ctrl134, ctrl138, ctrl142, ctrl146, ctrl150, ctrl154, ctrl158, ctrl162, ctrl166, ctrl170, ctrl174, ctrl178, ctrl182, ctrl186, ctrl190, ctrl194, ctrl198, ctrl202, ctrl206, ctrl210, ctrl214, ctrl218, ctrl222, ctrl226, ctrl230, ctrl234, ctrl238, ctrl242, ctrl246, ctrl251, ctrl252]]
    reg4                 = Join(QUInt(33))  [reg=[target126, target129, target132, target135, target138, target141, target144, target147, target150, target153, target156, target159, target162, target165, target168, target171, target174, target177, target180, target183, target186, target189, target192, target195, target198, target201, target204, target207, target210, target213, target216, target219, target220]]
                           return           [a=reg3, b=reg4]    
}


extern qdef CNOT
from qualtran.bloqs.basic_gates.CNOT
