#!/usr/bin/env bash

################################################################################
# Runs repository checks: format-incremental, ruff, mypy, and pytest-quick.
#
# Usage:
#     check/all
################################################################################

# Get the working directory to the repo root.
thisdir="$(dirname "${BASH_SOURCE[0]}")" || exit $?
topdir="$(git -C "${thisdir}" rev-parse --show-toplevel)" || exit $?
cd "${topdir}" || exit $?

if [ "$#" -ne 0 ]; then
    echo "Error: check/all does not accept arguments. To run customized checks, please invoke the individual check/* scripts directly." >&2
    exit 1
fi

run_check() {
    local cmd="$1"
    echo "${cmd}"
    "${cmd}"
    local exit_code=$?
    if [ ${exit_code} -ne 0 ]; then
        echo "" >&2
        echo "Check '${cmd}' failed. To diagnose or debug in isolation, run:" >&2
        echo "  ${cmd}" >&2
        exit ${exit_code}
    fi
}

run_check check/format-incremental
run_check check/ruff
run_check check/mypy
run_check check/pytest-quick
